{
  "schema_version": "hwai-mcp-public-bundle.v1",
  "bundle_name": "Humanswith.ai MCP Stack",
  "default_profile": "core",
  "distribution_repo": "https://github.com/g-shevchenko/hwai-mcp-stack.git",
  "bundled_source_dir": "source",
  "source_repo": "",
  "source_branch": "main",
  "workspace_env_file": "$HOME/.hwai/mcp-stack/env",
  "data_policy": {
    "local_raw_evidence": true,
    "central_exports": "aggregate-only",
    "forbidden_exports": [
      "raw code",
      "raw prompts",
      "raw URLs",
      "raw screenshots",
      "raw trace artifacts",
      "lockfiles",
      "env files",
      "Notion bodies"
    ]
  },
  "profiles": {
    "core": {
      "description": "Small default profile for daily agent work: routing, repo retrieval, noisy context prep, and deterministic checks.",
      "services": [
        "router-lite-mcp",
        "retrieval-mcp",
        "context-prep-mcp",
        "static-analysis-mcp",
        "repo-history-mcp",
        "repo-quality-gate-mcp"
      ]
    },
    "repo": {
      "description": "Repository hygiene and architecture support for large local repos.",
      "extends": [
        "core"
      ],
      "services": [
        "language-graph-mcp",
        "repo-hygiene-mcp",
        "docs-hygiene-mcp",
        "contract-schema-mcp",
        "dependency-risk-mcp",
        "docs-sync-mcp",
        "golden-dataset-mcp",
        "agent-trace-mcp",
        "test-results-mcp",
        "tdd-gate-mcp",
        "pbt-runner-mcp"
      ]
    },
    "browser-debug": {
      "description": "Browser debugging, screenshot prep, and local visual regression helpers.",
      "extends": [
        "core"
      ],
      "services": [
        "playwright-trace-mcp",
        "vision-mcp",
        "visual-baseline-mcp",
        "agent-trace-mcp"
      ]
    },
    "full": {
      "description": "All local token-efficiency MCPs. Use after core passes doctor.",
      "extends": [
        "repo",
        "browser-debug"
      ],
      "services": []
    }
  },
  "services": {
    "router-lite-mcp": {
      "client_name": "router_lite",
      "service_dir": "services/router-lite-mcp",
      "stdio": "services/router-lite-mcp/scripts/local-stdio.sh",
      "cache_dir": "$HOME/.hwai/router-lite-mcp",
      "category": "local-utility"
    },
    "retrieval-mcp": {
      "client_name": "retrieval",
      "service_dir": "services/retrieval-mcp",
      "stdio": "services/retrieval-mcp/scripts/local-stdio.sh",
      "cache_dir": "$HOME/.hwai/retrieval-mcp",
      "category": "local-utility"
    },
    "context-prep-mcp": {
      "client_name": "context_prep",
      "service_dir": "services/context-prep-mcp",
      "stdio": "services/context-prep-mcp/scripts/local-stdio.sh",
      "cache_dir": "$HOME/.hwai/context-prep-mcp",
      "category": "local-utility"
    },
    "static-analysis-mcp": {
      "client_name": "static_analysis",
      "service_dir": "services/static-analysis-mcp",
      "stdio": "services/static-analysis-mcp/scripts/local-stdio.sh",
      "cache_dir": "$HOME/.hwai/static-analysis-mcp",
      "category": "local-utility"
    },
    "repo-history-mcp": {
      "client_name": "repo_history",
      "service_dir": "services/repo-history-mcp",
      "stdio": "services/repo-history-mcp/scripts/local-stdio.sh",
      "cache_dir": "$HOME/.hwai/repo-history-mcp",
      "category": "local-utility"
    },
    "repo-quality-gate-mcp": {
