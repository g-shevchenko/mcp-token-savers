{
  "name": "@hwai/repo-quality-gate-mcp",
  "version": "0.1.2",
  "description": "Local-first advisory repo quality gate MCP for clean new work budgets",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "benchmark": "npm run build && node ./scripts/benchmark-local.mjs",
    "smoke": "bash ./scripts/smoke-local.sh",
    "measurement:report": "npm run build && node ./scripts/measurement-report.mjs",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "mcp",
    "quality-gate",
    "repo-hygiene",
    "docs-hygiene",
    "pantheon-safe"
  ],
  "author": "Humanswith.ai",
  "license": "MIT"
}
