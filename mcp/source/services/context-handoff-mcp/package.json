{
  "name": "@hwai/context-handoff-mcp",
  "version": "0.1.0",
  "description": "Local-first MCP for generic context pressure pre-scoring, operational handoffs, and cross-agent resume state",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js",
    "dev": "tsc --watch",
    "benchmark": "npm run build && node ./scripts/benchmark-local.mjs",
    "test": "npm run build && node --test test/*.test.mjs",
    "smoke": "bash ./scripts/smoke-local.sh",
    "measurement:report": "npm run build && node ./scripts/measurement-report.mjs",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "mcp",
    "context-engineering",
    "handoff",
    "token-efficiency",
    "local-first"
  ],
  "author": "Humanswith.ai",
  "license": "MIT"
}
