{
  "name": "@hwai/repo-history-mcp",
  "version": "1.1.0",
  "description": "Local-first git history MCP for compact repo history evidence and Pantheon-safe aggregate telemetry",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "benchmark": "npm run build && node ./scripts/benchmark-local.mjs",
    "smoke": "bash ./scripts/smoke-local.sh",
    "measurement:report": "npm run build && node ./scripts/measurement-report.mjs",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "mcp",
    "git",
    "repo-history",
    "pantheon-safe",
    "token-savings"
  ],
  "author": "Humanswith.ai",
  "license": "MIT"
}
