{
  "name": "@hwai/language-graph-mcp",
  "version": "0.1.1",
  "description": "Local-first language graph MCP for structural repo navigation, references, and blast-radius checks",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "benchmark": "npm run build && node ./scripts/benchmark-local.mjs",
    "smoke": "bash ./scripts/smoke-local.sh",
    "measurement:report": "npm run build && node ./scripts/measurement-report.mjs",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "mcp",
    "language-graph",
    "repo-navigation",
    "blast-radius",
    "token-savings"
  ],
  "author": "Humanswith.ai",
  "license": "MIT"
}
