{
  "name": "@hwai/contract-schema-mcp",
  "version": "0.1.1",
  "description": "Local-first contract/schema MCP for OpenAPI, Zod, env contracts, payload validation, and drift checks",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "benchmark": "npm run build && node ./scripts/benchmark-local.mjs",
    "smoke": "bash ./scripts/smoke-local.sh",
    "measurement:report": "npm run build && node ./scripts/measurement-report.mjs",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ajv": "^8.17.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "mcp",
    "contracts",
    "openapi",
    "zod",
    "env",
    "pantheon-safe"
  ],
  "author": "Humanswith.ai",
  "license": "MIT"
}
