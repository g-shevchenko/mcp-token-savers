{
  "name": "@hwai/dependency-risk-mcp",
  "version": "0.1.2",
  "description": "Local-first dependency risk MCP for lockfile diffs, licenses, audit summaries, OSV summaries, package age, and supply-chain lockfile signals",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "benchmark": "npm run build && node ./scripts/benchmark-local.mjs",
    "smoke": "bash ./scripts/smoke-local.sh",
    "measurement:report": "npm run build && node ./scripts/measurement-report.mjs",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "mcp",
    "dependencies",
    "lockfile",
    "license",
    "audit",
    "osv",
    "pantheon-safe"
  ],
  "author": "Humanswith.ai",
  "license": "MIT"
}
