{
  "name": "@hwai/static-analysis-mcp",
  "version": "1.0.0",
  "description": "Local-first static analysis MCP for compact deterministic verification before frontier model reasoning",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "benchmark": "npm run build && node ./scripts/benchmark-local.mjs",
    "smoke": "bash ./scripts/smoke-local.sh",
    "measurement:report": "npm run build && node ./scripts/measurement-report.mjs",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "mcp",
    "static-analysis",
    "verification",
    "sarif",
    "token-savings"
  ],
  "author": "Humanswith.ai",
  "license": "MIT"
}
